                 }
             };
 
+            // Floating-island layout: two layers.
+            //
+            // Outer rectangular div (`#dock-panel`) owns a rectangular
+            // `overflow_hidden` to clip any panel that doesn't bound its own
+            // height, so the dock can't push the workspace column past its
+            // allotted size and shove the status bar off-screen.
+            //
+            // Inner div is the rounded island: `panel_bg` fill plus
+            // `overflow_hidden + rounded_xl`. The rounded clip is enforced by
+            // `Style::overflow_mask` which carries the corner radii into the
+            // pushed `ContentMask`; child fragments are alpha-clipped along
+            // the rounded silhouette by the GPU shader's `rounded_mask_alpha`.
+            // Border tape no longer required: rounded ContentMask now does
+            // the alpha clip cleanly along the rounded silhouette
+            // (see patches/rounded-content-mask.patch).
+            let panel_bg = cx.theme().colors().panel_background;
             div()
                 .id("dock-panel")
                 .key_context(dispatch_context)
                 .track_focus(&self.focus_handle(cx))
                 .focus_follows_mouse(self.focus_follows_mouse, cx)
+                .relative()
                 .flex()
-                .bg(cx.theme().colors().panel_background)
-                .border_color(cx.theme().colors().border)
                 .overflow_hidden()
                 .map(|this| match self.position().axis() {
-                    // Width and height are always set on the workspace wrapper in
-                    // render_dock, so fill whatever space the wrapper provides.
                     Axis::Horizontal => this.w_full().h_full().flex_row(),
                     Axis::Vertical => this.h_full().w_full().flex_col(),
                 })
-                .map(|this| match self.position() {
-                    DockPosition::Left => this.border_r_1(),
-                    DockPosition::Right => this.border_l_1(),
-                    DockPosition::Bottom => this.border_t_1(),
-                })
                 .child(
                     div()
-                        .map(|this| match self.position().axis() {
-                            Axis::Horizontal => this.w_full().h_full(),
-                            Axis::Vertical => this.h_full().w_full(),
-                        })
+                        .size_full()
+                        .bg(panel_bg)
+                        .overflow_hidden()
+                        .rounded_xl()
                         .child(
-                            entry
-                                .panel
-                                .to_any()
-                                .cached(StyleRefinement::default().v_flex().size_full()),
+                            // pt/pb leave 4px so panel content doesn't sit
+                            // on the rounded clip edge.
+                            entry.panel.to_any().cached(
+                                StyleRefinement::default()
+                                    .v_flex()
+                                    .size_full()
+                                    .pt(px(4.))
+                                    .pb(px(4.)),
+                            ),
                         ),
                 )
                 .when(self.resizable(cx), |this| {
