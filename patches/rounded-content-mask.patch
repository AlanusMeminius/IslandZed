+    /// Per-corner radii of the rounded silhouette. Zero on every corner means a plain rectangular
+    /// mask (the silhouette check becomes a no-op).
+    pub corner_radii: Corners<P>,
+    /// Bounds of the rounded silhouette. The four corner curves are placed at the corners of this
+    /// rect, NOT at the corners of `bounds`. Set by `Style::overflow_mask` to the rounded
+    /// ancestor's element bounds, then preserved across rectangular `intersect`s so the silhouette
+    /// stays anchored to the original outer corners.
+    pub silhouette_bounds: Bounds<P>,
+}
