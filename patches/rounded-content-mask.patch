+#[cfg(test)]
+mod content_mask_tests {
+    use super::*;
+    use crate::{Pixels, point, px, size};
+
+    fn rect(x: f32, y: f32, w: f32, h: f32) -> Bounds<Pixels> {
+        Bounds {
+            origin: point(px(x), px(y)),
+            size: size(px(w), px(h)),
+        }
+    }
+
+    fn rect_mask(b: Bounds<Pixels>) -> ContentMask<Pixels> {
+        ContentMask {
+            bounds: b,
+            corner_radii: Corners::default(),
+            silhouette_bounds: b,
+        }
+    }
+
+    fn rounded_mask(b: Bounds<Pixels>, r: f32) -> ContentMask<Pixels> {
+        ContentMask {
+            bounds: b,
+            corner_radii: Corners::all(px(r)),
+            silhouette_bounds: b,
+        }
+    }
+
+    #[test]
+    fn default_has_zero_fields() {
+        let mask = ContentMask::<Pixels>::default();
+        assert_eq!(mask.bounds, Bounds::default());
+        assert_eq!(mask.corner_radii, Corners::default());
+        assert_eq!(mask.silhouette_bounds, Bounds::default());
+    }
+
+    #[test]
+    fn rectangular_helper_makes_silhouette_match_bounds() {
+        let mask = ContentMask::rectangular(rect(10., 20., 30., 40.));
+        assert_eq!(mask.bounds, rect(10., 20., 30., 40.));
+        assert_eq!(mask.corner_radii, Corners::default());
+        assert_eq!(mask.silhouette_bounds, rect(10., 20., 30., 40.));
+    }
+
+    #[test]
+    fn intersect_two_rectangular_masks_yields_rectangular_silhouette() {
+        let a = rect_mask(rect(0., 0., 100., 100.));
+        let b = rect_mask(rect(10., 10., 80., 80.));
+        let out = a.intersect(&b);
+        assert_eq!(out.bounds, rect(10., 10., 80., 80.));
+        assert_eq!(out.corner_radii, Corners::default());
+        // No rounded silhouette; silhouette_bounds collapses to the result's rect clip.
+        assert_eq!(out.silhouette_bounds, rect(10., 10., 80., 80.));
+    }
+
+    #[test]
+    fn intersect_with_rectangular_inner_preserves_outer_silhouette() {
+        // Floating-island scenario: outer rounded mask, inner rectangular sub-mask offset
+        // below. `bounds` shrinks to the inner; `silhouette_bounds + corner_radii` stays at the
+        // outer's original so the rounded curves are still anchored at the outer's corners.
+        let outer = rounded_mask(rect(0., 0., 800., 600.), 12.);
+        let inner = rect_mask(rect(0., 30., 800., 570.));
+        let out = inner.intersect(&outer);
+        assert_eq!(out.bounds, rect(0., 30., 800., 570.));
+        assert_eq!(out.corner_radii, Corners::all(px(12.)));
+        assert_eq!(out.silhouette_bounds, rect(0., 0., 800., 600.));
+    }
+
+    #[test]
+    fn intersect_is_symmetric_for_floating_island() {
+        // `inner.intersect(&outer)` and `outer.intersect(&inner)` must produce the same result
+        // because runtime callers may not control which side is `self`.
+        let outer = rounded_mask(rect(0., 0., 800., 600.), 12.);
+        let inner = rect_mask(rect(0., 30., 800., 570.));
+        let inner_first = inner.intersect(&outer);
+        let outer_first = outer.intersect(&inner);
+        assert_eq!(inner_first.bounds, outer_first.bounds);
+        assert_eq!(inner_first.corner_radii, outer_first.corner_radii);
+        assert_eq!(inner_first.silhouette_bounds, outer_first.silhouette_bounds);
+        assert_eq!(inner_first.corner_radii, Corners::all(px(12.)));
+        assert_eq!(inner_first.silhouette_bounds, rect(0., 0., 800., 600.));
+    }
+
+    #[test]
+    fn intersect_clamps_radii_to_half_of_silhouette_bounds() {
+        // Radii oversized for the silhouette get clamped against the silhouette's own size, not
+        // the (possibly much smaller) intersected rect-clip bounds.
+        let outer = rounded_mask(rect(0., 0., 100., 100.), 80.);
+        let inner = rect_mask(rect(0., 0., 30., 30.));
+        let out = outer.intersect(&inner);
+        // silhouette_bounds.size = 100x100 -> half = 50. Radius 80 clamps to 50.
+        assert_eq!(out.corner_radii, Corners::all(px(50.)));
+        assert_eq!(out.silhouette_bounds, rect(0., 0., 100., 100.));
+    }
+
+    #[test]
+    fn intersect_when_outer_is_rectangular_and_inner_is_rounded_uses_inner_silhouette() {
+        // Reverse scenario: a child explicitly opts into a rounded silhouette inside a
+        // rectangular ancestor. The inner's silhouette wins because the rectangular ancestor
+        // contributes no rounded shape.
+        let outer = rect_mask(rect(0., 0., 200., 200.));
+        let inner = rounded_mask(rect(20., 20., 100., 100.), 8.);
+        let out = inner.intersect(&outer);
+        assert_eq!(out.corner_radii, Corners::all(px(8.)));
+        assert_eq!(out.silhouette_bounds, rect(20., 20., 100., 100.));
+    }
+}
