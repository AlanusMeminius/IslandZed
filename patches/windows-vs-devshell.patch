diff --git a/script/bundle-windows.ps1 b/script/bundle-windows.ps1
index 53527e1b8f..acf5661875 100644
--- a/script/bundle-windows.ps1
+++ b/script/bundle-windows.ps1
@@ -32,23 +32,52 @@ function Get-VSArch {
     param(
         [string]$Arch
     )
 
     switch ($Arch) {
         "x86_64" { "amd64" }
         "aarch64" { "arm64" }
     }
 }
 
+function Get-VSDevShellPath {
+    $candidates = @()
+    $vsWhere = "${env:ProgramFiles(x86)}\Microsoft Visual Studio\Installer\vswhere.exe"
+
+    if (Test-Path $vsWhere) {
+        $installationPath = & $vsWhere -latest -products * -requires Microsoft.VisualStudio.Component.VC.Tools.x86.x64 -property installationPath
+        if ($LASTEXITCODE -eq 0 -and $installationPath) {
+            $candidates += Join-Path $installationPath "Common7\Tools\Launch-VsDevShell.ps1"
+        }
+    }
+
+    $visualStudioRoot = "${env:ProgramFiles}\Microsoft Visual Studio\2022"
+    foreach ($edition in @("Enterprise", "Professional", "Community", "BuildTools", "Preview")) {
+        $candidates += Join-Path $visualStudioRoot "$edition\Common7\Tools\Launch-VsDevShell.ps1"
+    }
+
+    foreach ($candidate in $candidates | Select-Object -Unique) {
+        if (Test-Path $candidate) {
+            return (Resolve-Path $candidate).Path
+        }
+    }
+
+    throw "Could not find Visual Studio DevShell. Install Visual Studio 2022 with the MSVC v143 toolset, or ensure vswhere.exe can locate Microsoft.VisualStudio.Component.VC.Tools.x86.x64."
+}
+
 Push-Location
-& "C:\Program Files\Microsoft Visual Studio\2022\Community\Common7\Tools\Launch-VsDevShell.ps1" -Arch (Get-VSArch -Arch $Architecture) -HostArch (Get-VSArch -Arch $OSArchitecture)
-Pop-Location
+try {
+    & (Get-VSDevShellPath) -Arch (Get-VSArch -Arch $Architecture) -HostArch (Get-VSArch -Arch $OSArchitecture)
+}
+finally {
+    Pop-Location
+}
 
 $target = "$Architecture-pc-windows-msvc"
 
 if ($Help) {
     Write-Output "Usage: test.ps1 [-Install] [-Help]"
     Write-Output "Build the installer for Windows.\n"
     Write-Output "Options:"
     Write-Output "  -Architecture, -a Which architecture to build (x86_64 or aarch64)"
     Write-Output "  -Install, -i      Run the installer after building."
     Write-Output "  -Help, -h         Show this help message."
